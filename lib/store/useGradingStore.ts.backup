// ─── INITIAL AUDIT LOG (seeded for demo) ──────────────────────────────────────

const INITIAL_AUDIT_LOG: AuditLogEntry[] = [
  { id: "A-920", timestamp: "2026-04-02 14:05:22", actor: "Prof. S. Kumar", action: "Score Override", targetSubmissionId: "sub-2", targetLabel: "ECO-023 (Meena Iyer)", details: "Changed 'Diminishing Returns' from 2→4. Reason: OCR Misread — smudge on Q2 confirmed via original scan.", actionColor: "warning" },
  { id: "A-921", timestamp: "2026-04-02 13:12:05", actor: "AI Engine", action: "Auto-Grade Complete", targetSubmissionId: "", targetLabel: "Batch ECO-101-MID", details: "Processed 142 submissions. Avg confidence: 0.84. Flagged 2 for integrity review, 1 all-Minimal confidence.", actionColor: "success" },
  { id: "A-922", timestamp: "2026-04-02 11:05:10", actor: "Prof. S. Kumar", action: "Feedback Scheduled", targetSubmissionId: "sub-8", targetLabel: "ECO-055 (Anjali Das)", details: "Feedback approved. Scheduled release: Monday, Apr 7 2026 at 09:00 AM.", actionColor: "default" },
  { id: "A-923", timestamp: "2026-04-01 09:14:00", actor: "AI Engine", action: "Integrity Flag", targetSubmissionId: "sub-4", targetLabel: "ECO-058 (Fatima Khan)", details: "87% semantic similarity detected with ECO-062 (Rahul Verma) on Q3 and Q4. Flagged for instructor review.", actionColor: "danger" },
  { id: "A-924", timestamp: "2026-04-01 08:30:11", actor: "System", action: "Rubric Calibration", targetSubmissionId: "", targetLabel: "Batch ECO-101-MID", details: "Calibration complete. AI aligned to instructor grading model. Delta: 0.12 on Criterion 3 interpretation.", actionColor: "default" },
];

// ─── STORE ─────────────────────────────────────────────────────────────────────

export const useGradingStore = create<GradingStore>((set, get) => ({
  batchId: "ECO-101-MID",
  batchName: "Midterm: Macroeconomics Analysis",
  totalSubmissions: 142,
  submissions: MOCK_SUBMISSIONS,

  // Pre-seeded session state for demo: shows "resumed session" banner on dashboard
  sessionState: {
    lastOpenedSubmissionId: "sub-2",
    savedAt: new Date(Date.now() - 3 * 60 * 60 * 1000).toISOString(),
  },

  auditLog: INITIAL_AUDIT_LOG,

  getProcessedCount: () => {
    const subs = Object.values(get().submissions);
    const approved = subs.filter(s => s.status === "Approved").length;
    return 120 + approved;
  },

  getSubmissionList: () => Object.values(get().submissions),

  overrideScore: (submissionId, criterionId, newScore, reasonCode, instructorId) =>
    set((state) => {
      const submission = state.submissions[submissionId];
      if (!submission) return state;

      const reasonLabel = REASON_LABELS[reasonCode];
      const now = new Date().toISOString();
      const criterion = submission.criteria.find(c => c.id === criterionId);
      if (!criterion) return state;

      const record: OverrideRecord = {
        criterionId,
        criterionTitle: criterion.title,
        originalScore: criterion.originalAiScore,
        newScore,
        reasonCode,
        reasonLabel,
        instructorId,
        timestamp: now,
      };

      const logEntry: AuditLogEntry = {
        id: `A-${Date.now()}`,
        timestamp: new Date().toLocaleString('en-IN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' }),
        actor: "Prof. S. Kumar",
        action: "Score Override",
        targetSubmissionId: submissionId,
        targetLabel: `${submission.paperId} (${submission.studentName})`,
        details: `${criterion.title}: ${criterion.originalAiScore}→${newScore}. Reason: ${reasonLabel}.`,
        actionColor: "warning",
      };

      const newCriteria = submission.criteria.map(c =>
        c.id === criterionId
          ? { ...c, score: newScore, isOverridden: true, overrideHistory: [...c.overrideHistory, record] }
          : c
      );

      return {
        submissions: {
          ...state.submissions,
          [submissionId]: { ...submission, criteria: newCriteria },
        },
        auditLog: [logEntry, ...state.auditLog],
      };
    }),

  approveSubmission: (submissionId) =>
    set((state) => {
      const submission = state.submissions[submissionId];
      if (!submission) return state;

      const logEntry: AuditLogEntry = {
        id: `A-${Date.now()}`,
        timestamp: new Date().toLocaleString('en-IN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' }),
        actor: "Prof. S. Kumar",
        action: "Submission Approved",
        targetSubmissionId: submissionId,
        targetLabel: `${submission.paperId} (${submission.studentName})`,
        details: `Final score: ${submission.criteria.reduce((a, c) => a + c.score, 0)}/${submission.criteria.reduce((a, c) => a + c.maxScore, 0)}. Approved by instructor.`,
        actionColor: "success",
      };

      return {
        submissions: {
          ...state.submissions,
          [submissionId]: { ...submission, status: "Approved" },
        },
        auditLog: [logEntry, ...state.auditLog],
      };
    }),

  updateFeedbackTone: (submissionId, tone) =>
    set((state) => {
      const submission = state.submissions[submissionId];
      if (!submission?.feedback) return state;
      return {
        submissions: {
          ...state.submissions,
          [submissionId]: { ...submission, feedback: { ...submission.feedback, tone } },
        },
      };
    }),

  updateFeedbackText: (submissionId, type, index, text) =>
    set((state) => {
      const submission = state.submissions[submissionId];
      if (!submission?.feedback) return state;
      const newArray = [...submission.feedback[type]];
      newArray[index] = text;
      return {
        submissions: {
          ...state.submissions,
          [submissionId]: { ...submission, feedback: { ...submission.feedback, [type]: newArray } },
        },
      };
    }),

  releaseFeedback: (submissionId) =>
    set((state) => {
      const submission = state.submissions[submissionId];
      if (!submission?.feedback) return state;

      const logEntry: AuditLogEntry = {
        id: `A-${Date.now()}`,
        timestamp: new Date().toLocaleString('en-IN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' }),
        actor: "Prof. S. Kumar",
        action: "Feedback Released",
        targetSubmissionId: submissionId,
        targetLabel: `${submission.paperId} (${submission.studentName})`,
        details: `Feedback released immediately. Tone: ${submission.feedback.tone}.`,
        actionColor: "success",
      };

      return {
        submissions: {
          ...state.submissions,
          [submissionId]: {
            ...submission,
            feedback: {
              ...submission.feedback,
              isReleased: true,
              releaseSchedule: { type: 'immediate' },
            },
          },
        },
        auditLog: [logEntry, ...state.auditLog],
      };
    }),

  scheduleFeedbackRelease: (submissionId, schedule) =>
    set((state) => {
      const submission = state.submissions[submissionId];
      if (!submission?.feedback) return state;

      const logEntry: AuditLogEntry = {
        id: `A-${Date.now()}`,
        timestamp: new Date().toLocaleString('en-IN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' }),
        actor: "Prof. S. Kumar",
        action: "Feedback Scheduled",
        targetSubmissionId: submissionId,
        targetLabel: `${submission.paperId} (${submission.studentName})`,
        details: schedule.type === 'scheduled'
          ? `Feedback scheduled for release: ${schedule.scheduledAt}.`
          : schedule.type === 'manual'
          ? 'Feedback approved and held — manual release required.'
          : 'Feedback approved for immediate release.',
        actionColor: "default",
      };

      return {
        submissions: {
          ...state.submissions,
          [submissionId]: {
            ...submission,
            feedback: { ...submission.feedback, releaseSchedule: schedule },
          },
        },
        auditLog: [logEntry, ...state.auditLog],
      };
    }),

  resolveAppeal: (submissionId, resolution) =>
    set((state) => {
      const submission = state.submissions[submissionId];
      if (!submission?.appeal) return state;

      const logEntry: AuditLogEntry = {
        id: `A-${Date.now()}`,
        timestamp: new Date().toLocaleString('en-IN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' }),
        actor: "Prof. S. Kumar",
        action: "Appeal Resolved",
        targetSubmissionId: submissionId,
        targetLabel: `${submission.paperId} (${submission.studentName})`,
        details: `Decision: ${resolution}. Criterion disputed: ${submission.appeal.criterionDisputed}.`,
        actionColor: resolution === "Uphold" ? "success" : resolution === "Reject" ? "danger" : "warning",
      };

      return {
        submissions: {
          ...state.submissions,
          [submissionId]: {
            ...submission,
            appeal: { ...submission.appeal, status: "Resolved" },
          },
        },
        auditLog: [logEntry, ...state.auditLog],
      };
    }),

  setSessionState: (partial) =>
    set((state) => ({
      sessionState: { ...state.sessionState, ...partial },
    })),

  bulkApproveSubmissions: (submissionIds) =>
    set((state) => {
      const now = new Date().toLocaleString('en-IN', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit' });
      const newSubmissions = { ...state.submissions };
      const newLogs: AuditLogEntry[] = [];

      for (const id of submissionIds) {
        const sub = newSubmissions[id];
        if (!sub || sub.status === "Approved") continue;
        newSubmissions[id] = { ...sub, status: "Approved" };
        newLogs.push({
          id: `A-${Date.now()}-${id}`,
          timestamp: now,
          actor: "Prof. S. Kumar",
          action: "Bulk Approved",
          targetSubmissionId: id,
          targetLabel: `${sub.paperId} (${sub.studentName})`,
          details: `Bulk approval — Strong confidence batch. Score: ${sub.criteria.reduce((a, c) => a + c.score, 0)}/${sub.criteria.reduce((a, c) => a + c.maxScore, 0)}.`,
          actionColor: "success",
        });
      }

      return {
        submissions: newSubmissions,
        auditLog: [...newLogs, ...state.auditLog],
      };
    }),
}));
