      { id: "q1", title: "1. Keynesian Economics Definition", score: 5, maxScore: 5, originalAiScore: 5, confidence: "Strong", confidenceColor: "success", evidence: "government spending acts as a multiplier, injecting demand that circulates through the economy and generates income multiple times its original value", rationale: "Exceptional answer — correctly identifies the Keynesian multiplier, explains market failure context, and uses precise terminology.", isOverridden: false, overrideHistory: [] },
      { id: "q2", title: "2. Law of Diminishing Returns", score: 5, maxScore: 5, originalAiScore: 5, confidence: "Strong", confidenceColor: "success", evidence: "beyond some point the marginal product of the variable input will decrease... Ceteris paribus is the critical assumption", rationale: "Perfect answer with a creative bakery example and explicit ceteris paribus statement.", isOverridden: false, overrideHistory: [] },
      { id: "q3", title: "3. Price Elasticity of Demand", score: 5, maxScore: 5, originalAiScore: 5, confidence: "Strong", confidenceColor: "success", evidence: "PED = %ΔQd / %ΔP. A value of –2 means a 10% price rise leads to a 20% fall in demand... four determinants listed", rationale: "Complete answer with formula, worked example, four determinants, and an India-specific illustration.", isOverridden: false, overrideHistory: [] },
